{
  "name": "ticket-timer",
  "version": "1.1.0",
  "description": "Support ticket time tracker overlay",
  "author": "Alexandre Homier",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node generate-icon.js && electron-builder build --win --publish never && node_modules\\electron-winstaller\\vendor\\rcedit.exe dist\\win-unpacked\\TicketTimer.exe --set-icon build\\icon.ico"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.tickettimer.app",
    "productName": "Ticket Timer",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "executableName": "TicketTimer"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "files": [
      "main.js",
      "preload.js",
      "overlay.html",
      "history.html",
      "ticket-detail.html",
      "debug.html",
      "session-notes.html",
      "package.json",
      "build/icon.ico"
    ],
    "asarUnpack": ["build/icon.ico"]
  }
}